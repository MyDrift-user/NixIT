# TEMPLATE — shows every key the fleet expects. Put the REAL values into the
# encrypted file:   sops secrets/common.yaml
# Do NOT commit a filled-in copy of this; common.yaml (sops-encrypted) is the
# only file that should hold real values.
#
# Generators:
#   password hash : mkpasswd -m sha-512
#   random secret : openssl rand -hex 32
#   your admin key: age-keygen -o ~/.config/sops/age/keys.txt   (public key -> .sops.yaml &admin)

# ── Admin login (all hosts) ────────────────────────────────────────────────
kuze/password: "$6$REPLACE"                 # mkpasswd -m sha-512

# ── Keycloak (svgmdl-keyc-01) — a docker env file ──────────────────────────
# The *_CLIENT_SECRET values are injected into the realm import; each must match
# the consumer's own secret below.
keycloak/env: |
  POSTGRES_PASSWORD=REPLACE
  KC_DB_PASSWORD=REPLACE                     # same value as POSTGRES_PASSWORD
  KEYCLOAK_ADMIN=admin
  KEYCLOAK_ADMIN_PASSWORD=REPLACE
  FORGEJO_CLIENT_SECRET=REPLACE
  OUTLINE_CLIENT_SECRET=REPLACE              # == outline/oidc-client-secret
  KASM_CLIENT_SECRET=REPLACE
  IMMICH_CLIENT_SECRET=REPLACE
  HEADSCALE_CLIENT_SECRET=REPLACE           # == headscale/oidc-client-secret
  EXCALIDASH_CLIENT_SECRET=REPLACE          # == excalidash/env OIDC_CLIENT_SECRET
  FREEIPA_CLIENT_SECRET=REPLACE             # FreeIPA `ipa idp-add --client-id freeipa --secret`

# ── Outline (svgmdl-outl-01) ───────────────────────────────────────────────
outline/secret-key: "REPLACE"               # openssl rand -hex 32
outline/utils-secret: "REPLACE"             # openssl rand -hex 32
outline/oidc-client-secret: "REPLACE"       # == OUTLINE_CLIENT_SECRET above

# ── Paperless (svgmdl-pape-01) ─────────────────────────────────────────────
paperless/admin-password: "REPLACE"

# ── Kasm (svgmdl-kasm-01) ──────────────────────────────────────────────────
kasm/admin-password: "REPLACE"

# ── Headscale (svgmdl-head-01) ─────────────────────────────────────────────
headscale/oidc-client-secret: "REPLACE"     # == HEADSCALE_CLIENT_SECRET above

# ── ExcaliDash (svgmdl-exca-01) ────────────────────────────────────────────
excalidash/env: |
  JWT_SECRET=REPLACE                         # openssl rand -hex 32
  CSRF_SECRET=REPLACE                        # openssl rand -hex 32
  OIDC_CLIENT_SECRET=REPLACE                 # == EXCALIDASH_CLIENT_SECRET above

# (immich + aliasvault need no app secret — immich uses local Postgres, AliasVault
#  generates its own keys into /srv/aliasvault/secrets)

# ── moodleng (svgmdl-mood-01) ──────────────────────────────────────────────
moodleng/db-env: |
  POSTGRES_PASSWORD=REPLACE
moodleng/app-env: |
  DATABASE_URL=postgres://moodleng:REPLACE@moodleng-db:5432/moodleng   # same pw as above
  JWT_SECRET=REPLACE                 # openssl rand -hex 32
  OPENAI_API_KEY=REPLACE             # AI features (optional, leave blank to disable)

# ── rumi (svgmdl-rumi-01) ──────────────────────────────────────────────────
rumi/db-env: |
  POSTGRES_PASSWORD=REPLACE
rumi/server-env: |
  RUMI__DATABASE__URL=postgres://rumi:REPLACE@rumi-db:5432/rumi        # same pw as above
  RUMI__AUTH__JWT_SECRET=REPLACE     # >=32 bytes; openssl rand -hex 32
  BOOTSTRAP_EMAIL=admin@example.com  # first admin (optional)
  BOOTSTRAP_PASSWORD=REPLACE

# ── FreeIPA DC (svgmdl-fipa-01) ────────────────────────────────────────────
freeipa/env: |
  PASSWORD=REPLACE                   # >=8 chars; sets admin + Directory Manager
# (Samba AD DC svgmdl-sada-01 uses secrets/ad-dc.yaml: ad/admin-password +
#  ca/intermediate-password — edit with `sops secrets/ad-dc.yaml`)

# ── FortiGate VPN gateway (svgwdc-svpn-01) ─────────────────────────────────
fortivpn/config: |
  host = vpn.fathercorp.example
  port = 443
  username = REPLACE
  password = REPLACE
  trusted-cert = REPLACE        # sha256; `openfortivpn host:port` prints it on first connect
  set-dns = 0
  pppd-use-peerdns = 0

# ── Pangolin newt tunnels — one site/creds per VM ──────────────────────────
newt/svgmdl-keyc-01: |
  PANGOLIN_ENDPOINT=https://your-pangolin
  NEWT_ID=REPLACE
  NEWT_SECRET=REPLACE
newt/svgmdl-forg-01: |
  PANGOLIN_ENDPOINT=https://your-pangolin
  NEWT_ID=REPLACE
  NEWT_SECRET=REPLACE
newt/svgmdl-outl-01: |
  PANGOLIN_ENDPOINT=https://your-pangolin
  NEWT_ID=REPLACE
  NEWT_SECRET=REPLACE
newt/svgmdl-pape-01: |
  PANGOLIN_ENDPOINT=https://your-pangolin
  NEWT_ID=REPLACE
  NEWT_SECRET=REPLACE
newt/svgmdl-kasm-01: |
  PANGOLIN_ENDPOINT=https://your-pangolin
  NEWT_ID=REPLACE
  NEWT_SECRET=REPLACE
newt/svgmdl-immi-01: |
  PANGOLIN_ENDPOINT=https://your-pangolin
  NEWT_ID=REPLACE
  NEWT_SECRET=REPLACE
newt/svgmdl-head-01: |
  PANGOLIN_ENDPOINT=https://your-pangolin
  NEWT_ID=REPLACE
  NEWT_SECRET=REPLACE
newt/svgmdl-exca-01: |
  PANGOLIN_ENDPOINT=https://your-pangolin
  NEWT_ID=REPLACE
  NEWT_SECRET=REPLACE
newt/svgmdl-alia-01: |
  PANGOLIN_ENDPOINT=https://your-pangolin
  NEWT_ID=REPLACE
  NEWT_SECRET=REPLACE
newt/svgmdl-game-01: |
  PANGOLIN_ENDPOINT=https://your-pangolin
  NEWT_ID=REPLACE
  NEWT_SECRET=REPLACE
